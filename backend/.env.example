# 服务器配置
APP_PORT=3000
NODE_ENV=development

# 前端地址（CORS 白名单，多个用逗号分隔）
FRONTEND_URL=http://localhost:5173

# 数据库配置（已切换为 MySQL，Windows 本地安装 MySQL 8.0）
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=aifeedback
DB_PASSWORD=your-strong-db-password
DB_NAME=ai_feedback

# SQLite 开发配置（可选）
# DB_TYPE=sqlite
# DB_LOCATION=./data/db.sqlite

# Redis 配置（AI 异步队列需要）
# 当前环境未安装 Redis，批量生成回退到内存队列模式
# REDIS_HOST=localhost
# REDIS_PORT=6379

# JWT 配置
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=7d

# DeepSeek API 配置
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# 文件上传配置
UPLOAD_MAX_SIZE=5242880
UPLOAD_DEST=./uploads

# 默认管理员初始密码（首次启动时创建管理员账号使用）
# 生产环境必须设置强密码，否则不会创建默认管理员
ADMIN_INITIAL_PASSWORD=your-strong-admin-password
